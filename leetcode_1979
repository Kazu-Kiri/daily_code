class Solution {
public:
    int gcd(int a,int b){
        if(b==0)return a;
        return gcd(b,a%b);
    }
    int findGCD(vector<int>& nums) {
        int min=1001;
        int max=0;
        for(int i:nums){
            min=i<min?i:min;
            max=i>max?i:max;
        }
        return gcd(max,min);
        
    }
};